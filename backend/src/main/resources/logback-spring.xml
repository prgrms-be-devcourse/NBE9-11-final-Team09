<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ===== 경로 설정 ===== -->
    <property name="LOG_DIR" value="logs"/>
    <property name="ERROR_LOG_DIR" value="logs/error"/>

    <!-- ===== 로그 패턴 설정 ===== -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5level] [%logger{0}] [%X{traceId:-NO_TRACE}] - %msg%n"/>
    <property name="CONSOLE_PATTERN"
              value="%d{HH:mm:ss.SSS} %highlight([%-5level]) %cyan([%logger{0}]) [%X{traceId:-NO_TRACE}] - %msg%n"/>

    <!-- ===== 콘솔 출력 ===== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!--
        전체 로그 파일 (INFO 이상)
        10MB 초과 시 260801.1.log 로 자동 분할
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/current.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/%d{yyMMdd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <!-- ===== ERROR 전용 파일 ===== -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${ERROR_LOG_DIR}/current.log</file>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${ERROR_LOG_DIR}/%d{yyMMdd}.%i.log</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>

    <!-- ===== 시스템 로그 필터링 (모든 환경 공통) ===== -->

    <logger name="org.hibernate.SQL" level="OFF"/>
    <logger name="org.hibernate.orm.jdbc.bind" level="OFF"/>
    <logger name="org.hibernate.orm.jdbc.extract" level="OFF"/>

    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.security" level="WARN"/>

    <logger name="org.apache" level="WARN"/>

    <logger name="com.zaxxer.hikari" level="WARN"/>

    <logger name="io.lettuce" level="WARN"/>

    <!-- ===== 로컬 환경: 콘솔만 ===== -->
    <springProfile name="local">
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.back.team9.moyeota" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <!-- ===== dev/prod 환경: 콘솔 + 파일 ===== -->
    <springProfile name="dev,prod">
        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
        <logger name="com.back.team9.moyeota" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </logger>
    </springProfile>

</configuration>